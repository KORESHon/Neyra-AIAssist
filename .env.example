# Скопируйте в ".env" в корне проекта и заполните значения.
# Файл .env в git не коммитится.

# ── Ядро LLM (OpenRouter по умолчанию) ─────────────────────────
OPENROUTER_API_KEY=
# Опционально: общий ключ для профилей llm.api_key / не-OpenRouter
# LLM_API_KEY=

# ── Discord ─────────────────────────────────────────────────────
DISCORD_TOKEN=

# ── Internal API (main.py --mode api) ─────────────────────────
# Если задан — подставляется в internal_api.token (перекрывает пустое поле в config.yaml)
# INTERNAL_API_TOKEN=

# ── Голос (облачные адаптеры) ─────────────────────────────────
DEEPGRAM_API_KEY=
GROQ_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# YANDEX_ID_KEY=

# ── Модели / Hugging Face ─────────────────────────────────────
# HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

# ── Плагины: свои ключи (добавьте имя в коде плагина через os.environ / getenv) ──
# Пример: кастомный поиск Яндекса — см. interfaces/000EXAMPLE/HELP.md
# YANDEX_SEARCH_API_KEY=

# ── Прочие интеграции ─────────────────────────────────────────
# EXTERNAL_API_KEY=
# SCREEN_PROXY_SECRET=
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# AGENT_PROXY_SECRET_KEY=
