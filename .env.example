# Скопируйте в ".env" в корне проекта и заполните значения.
# Файл .env в git не коммитится.

# ── Ядро LLM (OpenRouter по умолчанию) ─────────────────────────
OPENROUTER_API_KEY=
# Опционально: общий ключ для профилей llm.api_key / не-OpenRouter
# LLM_API_KEY=

# ── Discord (плагин discord_text) ─────────────────────────────
# Токен бота; настройки каналов — interfaces/discord_text/config.yaml
DISCORD_TOKEN=

# ── Локальный HTTP API ядра (плагин internal_api) ──────────────
# Это НЕ «облачный» API и не создаётся автоматически сайтом:
#   python main.py поднимает FastAPI на машине (host/port — interfaces/internal_api/config.yaml).
# Опционально: Bearer для запросов к /v1 и WebSocket (если пусто — без авторизации).
# INTERNAL_API_TOKEN=

# ── Голос (облачные адаптеры) ─────────────────────────────────
DEEPGRAM_API_KEY=
GROQ_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# YANDEX_ID_KEY=

# ── Модели / Hugging Face ─────────────────────────────────────
# HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

# ── Плагины: свои ключи (см. код плагина / getenv) ────────────
# YANDEX_SEARCH_API_KEY=

# ── Прочие интеграции ─────────────────────────────────────────
# SCREEN_PROXY_SECRET=
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# AGENT_PROXY_SECRET_KEY=
